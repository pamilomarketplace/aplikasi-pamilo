{
  "expo": {
    "name": "PAMILO",
    "slug": "PamiMarketplace",
    "version": "1.1.5",
    "scheme": "pamiloapp",
    "orientation": "portrait",
    "icon": "./assets/images/new_icon.png",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "android",
      "ios"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/d5d6367b-a81f-46d7-a2da-7fc7ac993459"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "id.pamilo.app",
      "associatedDomains": [
        "applinks:pamilo.store"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "id.pamilo.app",
      "versionCode": 8,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBkGf0g25APJjlwXCyKrqv3DIxG3vwXwmo"
        }
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "USE_FULL_SCREEN_INTENT",
        "SYSTEM_ALERT_WINDOW",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "pamiloapp"
            }
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/new_splash_icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#E5C9A6"
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/new_icon.png",
          "color": "#D35400",
          "sounds": [
            "./assets/sounds/migo.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aplikasi PAMILO membutuhkan izin GPS untuk menentukan akurasi titik pengantaran pesanan.",
          "locationAlwaysPermission": "Izinkan PAMILO melacak koordinat di latar belakang agar warga bisa melihat posisi Kurir.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5108422038162410~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "d5d6367b-a81f-46d7-a2da-7fc7ac993459"
      },
      "router": {}
    },
    "runtimeVersion": "1",
    "owner": "agieldoank"
  }
}